{
  "name": "heirloom",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "node scripts/analyze.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "lhci": "lhci autorun --config=./lighthouserc.cjs",
    "vercel-build": "node scripts/preflight-env.mjs && node scripts/migrate.mjs && next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,mdx}\" --cache",
    "check": "pnpm run lint && pnpm run typecheck",
    "i18n:validate": "node scripts/i18n-validate.mjs",
    "i18n:pseudo": "node scripts/i18n-pseudo.mjs",
    "audit:ci": "pnpm audit --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:backfill-tags": "tsx scripts/backfill-tag-taxonomy.ts",
    "db:backfill-dietary": "tsx scripts/backfill-dietary-tags.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.12.4",
    "@hookform/resolvers": "^3.10.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.475.0",
    "next": "^15.1.7",
    "next-cloudinary": "^6.17.5",
    "next-intl": "4.13.2",
    "postgres": "^3.4.5",
    "posthog-js": "^1.399.3",
    "qrcode-generator": "^2.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.1",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.50.1",
    "@serwist/next": "^9.0.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint": "8",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.7",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-i18next": "^6.1.5",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "serwist": "^9.0.11",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.6.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "unrs-resolver"
    ],
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-gpj5-g38j-94v9",
        "GHSA-ph9p-34f9-6g65"
      ]
    }
  }
}
