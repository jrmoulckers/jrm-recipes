# ---------------------------------------------------------------------------
# Heirloom environment variables.
# Copy to `.env` and fill in. EVERYTHING here is optional for local dev:
# with no values set, the app runs in "local/dev-bypass" mode (in-memory-ish
# auth + a local Postgres URL) so you can build and click around with no
# accounts. Fill these in for real data + production.
# ---------------------------------------------------------------------------

# --- Database (Postgres; Neon in prod, local docker in dev) ---
# Local docker default matches ./docker-compose.yml
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/heirloom"

# --- Auth (Clerk) — optional. When unset, dev-bypass auth is used locally. ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Where Clerk sends users. Defaults are fine.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- File uploads (Cloudinary) — optional for local dev. ---
# When unset, photo fields fall back to pasting an image URL.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- App ---
# Public base URL (used for share links + PWA). Optional in dev.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "1" to force the local dev-bypass auth even if Clerk keys exist.
# LOCAL/TEST ONLY: any deployed environment (preview or production) requires real
# Clerk keys. A deploy with this set (or with Clerk keys missing) fails closed —
# production refuses to build/boot, preview refuses per request — so never set it
# on a deploy.
# NEXT_PUBLIC_DEV_AUTH_BYPASS="1"

# --- Error monitoring (Sentry) — optional, wired in a later phase. ---
# NEXT_PUBLIC_SENTRY_DSN=""

# --- Product analytics (PostHog) — optional, privacy-first + cookieless. ---
# When unset, the entire analytics layer degrades to a no-op (no events, no
# cookies) so the app runs with zero config. Set the project key to enable it.
# Capture is routed through a first-party /ingest proxy (see next.config.js).
# NEXT_PUBLIC_POSTHOG_KEY=""
# Ingestion host. Defaults to https://us.i.posthog.com. Use https://eu.i.posthog.com
# for EU hosting, or your self-hosted instance URL.
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# Consent model. Unset (default) uses an opt-out model: capture is on when a key
# is configured, but always honors browser Do Not Track / Global Privacy Control
# and an in-app opt-out toggle. Set to "1" to require explicit opt-in consent
# (GDPR-style) — no events are sent until the user accepts the first-run notice.
# NEXT_PUBLIC_ANALYTICS_REQUIRE_CONSENT="1"

# --- Billing (Stripe) — optional. ---
# When unset, all subscription/paywall flows no-op and the app stays fully
# usable on the Free tier (pricing page is read-only, upgrade CTAs are disabled).
# Set these to enable Stripe Checkout, the Customer Portal, and webhooks.
# STRIPE_SECRET_KEY=""            # server-only secret key (sk_test_… / sk_live_…)
# STRIPE_WEBHOOK_SECRET=""        # signing secret for /api/stripe/webhook (whsec_…)
# STRIPE_PRICE_FAMILY=""          # recurring Price ID for the Family plan (price_…)
# STRIPE_PRICE_GIFT_FAMILY=""     # one-time Price ID for a gift purchase (price_…)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""  # client-safe publishable key (pk_…)
